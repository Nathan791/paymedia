<?php
session_start();

$connection = new mysqli("localhost", "root", "", "paymedia");

if ($connection->connect_error) {
    die("Connection failed: " . $connection->connect_error);
}

$company_name = "";
$email = "";
$password = password_hash("", PASSWORD_DEFAULT);

if (empty($company_name) || empty($email) || empty($password)) {
        $error_msg = "Please fill in all fields.";
    } else {
        $company_name = mysqli_real_escape_string($connection, $company_name);
        $email = mysqli_real_escape_string($connection, $email);
        $password = mysqli_real_escape_string($connection, $password);

        $stmt = $connection->prepare("INSERT INTO users (company_name, email, password) VALUES (?, ?, ?)");
        $stmt->bind_param("sss", $company_name, $email, $password);
        $stmt->execute();
        $result = $stmt->get_result();

        if ($result->num_rows > 0) {
            $user = $result->fetch_assoc();
            $_SESSION["editor_id"] = $user["id"];
            $_SESSION["editor_company_name"] = $user["company_name"];
            header("Location: index.php");
            exit();
        } else {
            $error_msg = "Registration failed. Please try again.";
        }
    }
?>
